    | xargs -I{} basename {} .yml | sort \
    | while read -r n; do printf "  %s\n" "$n"; done

  echo ""
  cmd_cert_list
}


### ═══════════════════════════════════════════════════════════════════════════
### KOMMANDO: hestia-sync
### Pollt HestiaCP-API, legt neue/entfernte Domains in PowerDNS + Traefik an
### ═══════════════════════════════════════════════════════════════════════════

cmd_hestia_sync() {
  log "HestiaCP-Domain-Sync"
  mkdir -p "$STATE_DIR"
  [[ -f "$HESTIA_STATE" ]] || echo "{}" > "$HESTIA_STATE"

  # HestiaCP REST-API: access_key + secret_key als POST-Felder
  local hestia_auth="access_key=${HESTIA_ACCESS_KEY}&secret_key=${HESTIA_SECRET_KEY}"

  # Verbindungstest
  local hc_code
  hc_code=$(curl -sk -o /dev/null -w "%{http_code}" -X POST "${HESTIA_API}" \
    --data "${hestia_auth}&cmd=v-list-users&arg1=json") || true
  case "$hc_code" in
    000) die "HestiaCP nicht erreichbar (${HESTIA_IP}) — LXC online?" ;;
    200) : ;;
    *)   die "HestiaCP-API HTTP ${hc_code} — Keys und IP-Whitelist prüfen (Einstellungen → Sicherheit)" ;;
  esac

  # Alle User abrufen
  local all_users
  all_users=$(curl -sk -X POST "${HESTIA_API}" \
    --data "${hestia_auth}&cmd=v-list-users&arg1=json" \
    | jq -r 'keys[]' 2>/dev/null) \
    || die "HestiaCP-API: ungültige Antwort"

  # Aktuelle Domains als JSON: { "user": ["domain1", "domain2"], ... }
  local current_json="{}"
  while IFS= read -r huser; do
    [[ -z "$huser" ]] && continue
    local user_domains
    user_domains=$(curl -sk -X POST "${HESTIA_API}" \
      --data "${hestia_auth}&cmd=v-list-web-domains&arg1=${huser}&arg2=json" \
      | jq -r 'keys[]' 2>/dev/null | jq -R . | jq -s .) || continue
    current_json=$(echo "$current_json" \
      | jq --arg u "$huser" --argjson d "$user_domains" '.[$u] = $d')
  done <<< "$all_users"

  local known_json
  known_json=$(cat "$HESTIA_STATE")

  # Neue Domains = in current aber nicht in known
  local new_domains
  new_domains=$(jq -rn     --argjson cur "$current_json"     --argjson known "$known_json"     '($cur | to_entries[]) as $e |
     ($known[$e.key] // []) as $k |
     ($e.value - $k)[] |
     . + " " + $e.key')   # "domain user"

  # Entfernte Domains = in known aber nicht in current
  local removed_domains
  removed_domains=$(jq -rn     --argjson cur "$current_json"     --argjson known "$known_json"     '($known | to_entries[]) as $e |
     ($cur[$e.key] // []) as $c |
     ($e.value - $c)[] |
     . + " " + $e.key')   # "domain user"

  local changed=0

  # Neue Domains anlegen
  if [[ -n "$new_domains" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local domain huser
      domain="${line%% *}"
      huser="${line##* }"
      log "Neue HestiaCP-Domain: ${domain} (User: ${huser})"
      cmd_add_web "$domain"
      changed=1
    done <<< "$new_domains"
  fi

  # Entfernte Domains aufräumen
  if [[ -n "$removed_domains" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local domain huser
      domain="${line%% *}"
      huser="${line##* }"
      log "Domain aus HestiaCP entfernt: ${domain} (User: ${huser})"
      # Nur Traefik-Config entfernen, Zone bleibt (könnte noch Mail haben)
      remove_traefik_config "$(safe_name "$domain")"
      log "Traefik-Config fuer ${domain} entfernt (Zone bleibt erhalten)"
      changed=1
    done <<< "$removed_domains"
  fi

  if [[ $changed -eq 0 ]]; then
    log "Keine Aenderungen in HestiaCP"
  fi

  # State aktualisieren
  echo "$current_json" > "$HESTIA_STATE"
  log "HestiaCP-Sync abgeschlossen"
}


### ═══════════════════════════════════════════════════════════════════════════
### KOMMANDO: init-config
### Erstellt eine kommentierte Beispiel-Konfigurationsdatei
### ═══════════════════════════════════════════════════════════════════════════

cmd_init_config() {
  local target="${1:-/etc/dns-mgr/dns-mgr.conf}"
  if [[ -f "$target" ]]; then
    read -r -p "${target} existiert bereits. Ueberschreiben? [j/N] " confirm
    [[ "$confirm" != "j" && "$confirm" != "J" ]] && { log "Abgebrochen"; exit 0; }
  fi
  mkdir -p "$(dirname "$target")"
  chmod 700 "$(dirname "$target")"

  cat > "$target" << 'CONF'
# =============================================================================
# dns-mgr Konfiguration
# Ort:    /etc/dns-mgr/dns-mgr.conf
# Rechte: chmod 600 (enthaelt API-Keys)
# =============================================================================

# ── PowerDNS (LXC 119) ───────────────────────────────────────────────────────
PDNS_API="http://192.168.1.119:8081/api/v1"
PDNS_KEY="DEIN-POWERDNS-API-KEY"

# ── Traefik (lokal auf LXC 120) ──────────────────────────────────────────────
TRAEFIK_CONF_DIR="/etc/traefik/conf.d"
ACME_JSON="/var/lib/traefik/acme.json"
ACME_RESOLVER="letsencrypt"

# ── Mailcow (LXC 106) ────────────────────────────────────────────────────────
MAILCOW_IP="192.168.1.106"
MAILCOW_KEY="DEIN-MAILCOW-API-KEY"
MAILCOW_IPV6="2a01:4f8:10b:f101::106"
MAILCOW_CERT_DIR="/opt/mailcow-dockerized/data/assets/ssl"
MAILCOW_COMPOSE_DIR="/opt/mailcow-dockerized"

# ── HestiaCP (LXC 118) ───────────────────────────────────────────────────────
# Access Key erstellen: v-add-access-key admin dns-mgr dns-mgr json
HESTIA_IP="192.168.1.118"
HESTIA_USER="admin"
HESTIA_ACCESS_KEY="DEIN-ACCESS-KEY"
HESTIA_SECRET_KEY="DEIN-SECRET-KEY"

# ── Oeffentliche Adressen ─────────────────────────────────────────────────────
PUBLIC_IPV4="DEINE-HETZNER-IPv4"
IPV6_PREFIX="2a01:4f8:10b:f101"   # /64-Prefix OHNE :: am Ende

# ── DNS / Nameserver ─────────────────────────────────────────────────────────
MAIL_HOSTNAME="mail.DEINE-HAUPTDOMAIN.tld"
SOA_HOSTMASTER="hostmaster.DEINE-HAUPTDOMAIN.tld."
NS_RECORDS=(
  "ns1.DEINE-HAUPTDOMAIN.tld."
  "ns2.DEINE-HAUPTDOMAIN.tld."   # VPS Fremd-Hoster Secondary NS
  "helium.ns.hetzner.de."
  "oxygen.ns.hetzner.com."
  "hydrogen.ns.hetzner.com."
)

# ── Zertifikat-Deployment-Targets ────────────────────────────────────────────
# Jeder Eintrag: [name]="host:cert-pfad:key-pfad:reload-cmd:main-domain"
#
#   name        Frei waehlbarer Name (fuer --target <name>)
#   host        SSH-Ziel IP. Leer lassen fuer lokales Deployment.
#   cert-pfad   Vollstaendiger Pfad zur cert.pem auf dem Zielhost
#   key-pfad    Vollstaendiger Pfad zur key.pem auf dem Zielhost
#   reload-cmd  Shell-Kommando nach Update auf dem Zielhost. Leer = keines.
#   main-domain Muss mit domain.main in acme.json uebereinstimmen
#               (= erste Domain in der Traefik-Route)
#
# Mailcow: SAN-Cert fuer alle mail.* Subdomains aller Mail-Domains.
# main-domain = erste mail.* Domain die mit add-mail angelegt wurde.
declare -A CERT_TARGETS
CERT_TARGETS=(
  [mailcow]="192.168.1.106:/opt/mailcow-dockerized/data/assets/ssl/cert.pem:/opt/mailcow-dockerized/data/assets/ssl/key.pem:cd /opt/mailcow-dockerized && docker compose restart nginx-mailcow postfix-mailcow dovecot-mailcow:mail.DEINE-HAUPTDOMAIN.tld"

  # Mumble-Beispiel:
  # [mumble]="192.168.1.132:/etc/mumble-server/cert.pem:/etc/mumble-server/key.pem:systemctl restart mumble-server:mumble.DEINE-DOMAIN.tld"

  # Lokales Deployment (z.B. SSHFS-Mount, kein SSH):
  # [lokal]=":/lokaler/pfad/cert.pem:/lokaler/pfad/key.pem::app.DEINE-DOMAIN.tld"
)

# ── State-Verzeichnis ─────────────────────────────────────────────────────────
# Hier speichert dns-mgr bekannte Domains (fuer hestia-sync, mailcow-sync)
# und MTA-STS IDs. Normalerweise nicht aendern.
STATE_DIR="/var/lib/dns-mgr"
CONF

  chmod 600 "$target"
  log "Konfigurationsdatei erstellt: ${target}"
  log "Bitte alle DEIN-* Platzhalter anpassen, dann:"
  log "  chmod 600 ${target}"
}

### ═══════════════════════════════════════════════════════════════════════════
### DISPATCHER
### ═══════════════════════════════════════════════════════════════════════════

case "${1:-help}" in
  add-web)       shift; cmd_add_web "$@" ;;
  add-mail)      shift; cmd_add_mail_records "$@" ;;
  add-srv)       shift; cmd_add_srv "$@" ;;
  add-service)   shift; cmd_add_service "$@" ;;
  remove)        shift; cmd_remove "$@" ;;
  mailcow-sync)    shift; cmd_mailcow_sync "$@" ;;
  update-mta-sts) shift; cmd_update_mta_sts "$@" ;;
  hestia-sync)   shift; cmd_hestia_sync "$@" ;;
  deploy-certs)  shift; cmd_deploy_certs "$@" ;;
  watch-certs)   shift; cmd_watch_certs "$@" ;;
  cert-list)     cmd_cert_list ;;
  list)          cmd_list ;;
  init-config)   shift; cmd_init_config "${1:-}" ;;
  help|--help|-h|*)
    cat <<'HELP'
dns-mgr — DNS · Traefik · Zertifikate

DOMAIN-VERWALTUNG
  add-web <domain> [--mail] [--ipv6=::XYZ]
      Zone, A/AAAA-Records, Traefik-Route → HestiaCP
      Subdomains werden in bestehende Zonen eingetragen
      --mail: gleichzeitig Mail-Records anlegen

  add-srv <zone> <service> <proto> <prio> <weight> <port> <target>
      Generischer SRV-Record setzen
      Beispiel: dns-mgr add-srv nfsmw15.de mumble tcp 0 10 64739 mumble.nfsmw15.de

  add-mail <domain>
      MX, SPF, DKIM, DMARC, MTA-STS, TLSRPT, SRV
      Traefik: mail/webmail/autoconfig/autodiscover/mta-sts → Mailcow
      Mailcow SAN-Zertifikat wird automatisch aktualisiert

  add-service <domain> <backend-ip> <port> [optionen]
      Beliebiger Dienst: DNS + Traefik
      --type=tcp                TCP statt HTTP
      --tcp-listen-port=<p>     Pflicht bei TCP
      --ipv6=::CTID             IPv6 (Suffix, CTID oder volle Adresse)
      --no-dns                  Nur Traefik, kein DNS
      --no-ipv6                 Nur A-Record, kein AAAA (für interne Dienste)
      --no-traefik              Nur DNS, keine Traefik-Route (Mumble, TS — direkt per NAT)
      --insecure                Backend-Zertifikat nicht prüfen (pfSense, Proxmox etc.)
      --subdomain-of=<zone>     Zone explizit angeben

  remove <domain> [--force]
      Zone + Traefik-Configs löschen

  mailcow-sync
      Mailcow-API pollen, neue Domains anlegen (fuer Cron)

  update-mta-sts
      MTA-STS IDs aus Mailcow API lesen und PowerDNS Records aktualisieren

  hestia-sync
      HestiaCP-API pollen, neue/entfernte Web-Domains synchronisieren
      Erkennt neue Domains (add-web) und entfernte Domains (Traefik aufraeumen)
      Empfohlen: jede Minute per Cron statt Hook-Scripts

ZERTIFIKATE
  deploy-certs [--target <n>] [--force]
      Zertifikate aus acme.json deployen
      Targets konfiguriert in CERT_TARGETS (oben im Script)

  watch-certs [--settle=<sek>]
      Dauerhaft: acme.json überwachen, bei Änderung deployen
      Als systemd-Service: watch-cert.service

  cert-list
      Konfigurierte Targets + Zertifikate in acme.json

ÜBERSICHT
  list          Zonen, Traefik-Configs, Cert-Targets

EINRICHTUNG
  init-config [pfad]
      Erstellt kommentierte Beispiel-Konfiguration
      Standard: /etc/dns-mgr/dns-mgr.conf

BEISPIELE
  dns-mgr add-web example.com
  dns-mgr add-web shop.example.com                        # Subdomain
  dns-mgr add-web example.com --mail                      # Web + Mail
  dns-mgr add-mail example.com                            # nur Mail
  dns-mgr add-service cloud.example.com 192.168.1.130 80 --ipv6=::130
  dns-mgr add-service ts.example.com 192.168.1.131 9987 --type=tcp --tcp-listen-port=9987
  dns-mgr add-service ha.example.com 192.168.178.10 8123 --no-dns
  dns-mgr deploy-certs                                    # alle Targets
  dns-mgr deploy-certs --target mailcow --force
  dns-mgr hestia-sync                             # manuell testen
  dns-mgr hestia-sync                             # via Cron: * * * * *
  dns-mgr watch-certs                                     # Watcher starten
  dns-mgr init-config                                     # Ersteinrichtung
  DNS_MGR_CONF=/andere/config.conf dns-mgr list           # andere Config
HELP
    ;;
esac

cmd_list() {
  echo ""
  echo "PowerDNS-Zonen:"
  pdns_get "/servers/localhost/zones" \
    | jq -r '.[].name' | sed 's/\.$//' | sort \
    | while read -r z; do printf "  %s\n" "$z"; done

  echo ""
  echo "Traefik-Configs (${TRAEFIK_CONF_DIR}):"
